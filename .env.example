DATABASE_URL=postgresql+psycopg://lipdub:lipdub@postgres:5432/lipdub
REDIS_URL=redis://redis:6379/0
DUBBING_QUEUE=dubbing
RESULT_DIR=/app/storage/results
WORKER_TEMP_DIR=/app/storage/worker-temp
HF_HOME=/app/storage/model-cache
LOG_LEVEL=INFO
WORKER_CONCURRENCY=1

WHISPER_MODEL=openai/whisper-large-v3
NLLB_MODEL=facebook/nllb-200-1.3B
NLLB_SOURCE_LANGUAGE_CODE=eng_Latn
REQUIRE_CUDA=true
COMMAND_TIMEOUT_SECONDS=3600

ELEVENLABS_API_KEY=
# Used only when ELEVENLABS_REFERENCE_AUDIO_PATH is unset or the job has no source video.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Optional static reference audio for testing. Leave unset in production so each uploaded
# video is used as the ElevenLabs voice clone reference.
ELEVENLABS_REFERENCE_AUDIO_PATH=
ELEVENLABS_CLONED_VOICE_NAME=Cubell cloned voice
ELEVENLABS_REFERENCE_AUDIO_SECONDS=60
SYNC_API_KEY=
# Backwards-compatible fallback also supported: SYNCLABS_API_KEY
SYNC_MODEL=lipsync-2
SYNC_POLL_INTERVAL_SECONDS=5
SYNC_POLL_TIMEOUT_SECONDS=900

# Optional Cloudflare R2 storage. Required when the backend stores original_video_path
# as an object key such as uploads/<file>.mp4 instead of a shared local path.
# Required for Sync.so lip sync because Sync.so v2 needs public video/audio URLs.
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_ENDPOINT_URL=
R2_PUBLIC_URL=
R2_PRESIGNED_URL_EXPIRATION_SECONDS=3600
