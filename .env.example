DATABASE_URL=postgresql+psycopg://lipdub:lipdub@postgres:5432/lipdub
REDIS_URL=redis://redis:6379/0
DUBBING_QUEUE=dubbing
RESULT_DIR=/app/storage/results
WORKER_TEMP_DIR=/app/storage/worker-temp
HF_HOME=/app/storage/model-cache
LOG_LEVEL=INFO
WORKER_CONCURRENCY=1

WHISPER_MODEL=openai/whisper-large-v3
NLLB_MODEL=facebook/nllb-200-1.3B
NLLB_SOURCE_LANGUAGE_CODE=eng_Latn
REQUIRE_CUDA=true
COMMAND_TIMEOUT_SECONDS=3600

# Point these at checked-out Fish Speech checkpoints and MuseTalk inference script inside the image.
FISH_SPEECH_MODEL_PATH=/workspace/fish-speech/checkpoints/s2-pro
# Optional Fish Speech voice-cloning prompt. Leave unset for random voice generation.
FISH_SPEECH_PROMPT_TEXT=
FISH_SPEECH_PROMPT_TOKENS_PATH=
MUSETALK_SCRIPT=/workspace/musetalk/inference.sh

# Optional Cloudflare R2 storage. Required when the backend stores original_video_path
# as an object key such as uploads/<file>.mp4 instead of a shared local path.
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_ENDPOINT_URL=
R2_PUBLIC_URL=
R2_PRESIGNED_URL_EXPIRATION_SECONDS=3600
